# Copy to .env (optional). The service runs in mock mode with no config at all.

# "mock" (default, no key needed) or "anthropic"
LLM_PROVIDER=mock

# Only used when LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Rate limiting
RATE_LIMIT=5
RATE_WINDOW_SECONDS=60

# LLM retry attempts on transient failure
LLM_MAX_RETRIES=2
